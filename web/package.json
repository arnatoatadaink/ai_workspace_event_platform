{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "analyze": "tsx --tsconfig tsconfig.scripts.json scripts/analysis/checker.ts",
    "analyze:ir": "tsx --tsconfig tsconfig.scripts.json scripts/analysis/ir-exporter.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@xyflow/react", "vite"]
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@types/react-plotly.js": "^2.6.4",
    "@xyflow/react": "^12.10.2",
    "plotly.js": "^3.5.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-plotly.js": "^2.6.0"
  }
